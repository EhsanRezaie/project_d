# ============================================
# Database & Redis
# ============================================
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dating_db
REDIS_URL=redis://localhost:6379

# ============================================
# Security
# ============================================
SECRET_KEY=change-this-to-64-random-characters-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ============================================
# Google OAuth (optional)
# ============================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Admin
# ============================================
ADMIN_SECRET_KEY=change-this-to-random-string

# ============================================
# App Settings
# ============================================
APP_NAME=DatingApp
DEBUG=False

# ============================================
# Session 11: Daily Limits & Rewards
# ============================================

# Free user daily limits
FREE_USER_DAILY_LIKES=20
FREE_USER_DAILY_CHATS=10

# Ad reward bonuses (per ad watched)
AD_REWARD_LIKES_BONUS=5
AD_REWARD_CHATS_BONUS=3

# Ad reward limits
MAX_AD_REWARDS_PER_DAY=2

# Welcome bonus (new user registration)
WELCOME_BONUS_DAYS=7

# Referral rewards
REFERRAL_INVITER_DAYS=3
REFERRAL_INVITED_DAYS=3

# Subscription plans (in days)
SUBSCRIPTION_MONTHLY_DAYS=30
SUBSCRIPTION_QUARTERLY_DAYS=90
SUBSCRIPTION_YEARLY_DAYS=365

# Subscription discounts (percentage)
SUBSCRIPTION_QUARTERLY_DISCOUNT=15
SUBSCRIPTION_YEARLY_DISCOUNT=30

# ============================================
# Payment (ZarinPal)
# ============================================
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=https://yourdomain.com/api/v1/subscriptions/verify

# ============================================
# File Uploads
# ============================================
UPLOADS_DIR=uploads
MAX_PHOTO_SIZE_MB=5
MAX_PHOTOS_PER_USER=6