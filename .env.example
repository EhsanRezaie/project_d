# ============================================
# Database & Redis
# ============================================
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/dating_db
REDIS_URL=redis://localhost:6379

# ============================================
# Security
# ============================================
SECRET_KEY=change-this-to-64-random-characters-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15

# ============================================
# Google OAuth (optional)
# ============================================
GOOGLE_CLIENT_ID=somenumbers.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

# ============================================
# Admin
# ============================================
ADMIN_SECRET_KEY=change-this-to-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=

# ============================================
# App Settings
# ============================================
APP_NAME=DatingApp
DEBUG=False

# ============================================
# Payment (ZarinPal)
# ============================================
ZARINPAL_MERCHANT_ID=
ZARINPAL_SANDBOX=true
ZARINPAL_CALLBACK_URL=https://yourdomain.com/api/v1/subscriptions/verify

# ============================================
# File Uploads MinIO
# ============================================
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
S3_PUBLIC_BUCKET=photos-public
S3_PRIVATE_BUCKET=photos-private
S3_PUBLIC_BASE_URL=http://localhost:9000/photos-public
S3_SIGNED_URL_EXPIRE_SECONDS=900

# ============================================
# Upload Limits
# ============================================
MAX_PHOTO_SIZE_MB=10
MAX_PHOTOS_PER_USER=9

# ============================================
# Sentry (error tracking — set DSN in production .env)
# ============================================
GLITCHTIP_DSN=http://public_key@localhost:8080/1

# ============================================
# FCM Push Notifications
# ============================================
FCM_SERVICE_ACCOUNT_PATH=firebase-service-account.json

